generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role{
  OWNER
  ADMIN
  STAFF
}

enum UserStatus{
  AKTIF
  NONAKTIF
}

enum PurchaseStatus{
  DITERIMA
  SEBAGIAN
  TERTUNDA
  DIORDER
}

enum SalePurchaseStatus{
  JATUH_TEMPO
  DIBAYAR
  SEBAGIAN
  TERTUNDA
}

enum SaleStatus{
  SELESAI
  TERTUNDA
}

enum PaymentMethods{
  TUNAI
  TRANSFER
  LAINNYA
}

enum PackagingStatus{
  SEDANG_MENGIRIM
  TERKIRIM
}

model Store{
  id String @id
  name String
  email String
  noWa String
  address String
  createdAt DateTime @default(now())

  user User[]
  customerGroup CustomerGroup[]
  customerUser CustomerUser[]
  supplier Supplier[]
  productCategories ProductCategories[]
  product Product[]
  purchase Purchase[]
  purchaseOrder PurchaseOrder[]
  savingAccounts SavingAccounts[]
  sales Sales[]
  saleOrder SaleOrder[]
  expenditureCategory ExpenditureCategory[]
  expenditures Expenditures[]
  saleReturns SaleReturns[]
  purchaseReturns PurchaseReturns[]
  packaging Packaging[]
  saleReturnOrders SaleReturnOrders[]
  purchaseReturnOrders PurchaseReturnOrders[]
}

model User{
  id String @id
  idStore String?
  username String @unique
  name String
  email String
  password String
  noWa String
  role Role
  status UserStatus
  createdAt DateTime @default(now())

  store Store? @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model CustomerGroup{
  id String @id
  idStore String
  name String
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  customerGroup CustomerUser[]
}

model CustomerUser{
  id String @id
  idStore String
  idCustomerGroup String?
  name String
  email String
  noWa String
  address String?
  city String
  zipCode String
  region String
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  customerGroup CustomerGroup? @relation(fields: [idCustomerGroup], references: [id], onDelete: SetNull, onUpdate: Cascade)
  sales Sales[]
  saleReturns SaleReturns[]
  packaging Packaging[]
}

model Supplier{
  id String @id
  idStore String
  name String
  email String
  noWa String
  address String?
  city String
  zipCode String
  region String
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  purchase Purchase[]
  purchaseReturns PurchaseReturns[]
}

model SavingAccounts{
  id String @id
  idStore String
  name String
  startingBalance Int
  notes String?
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  expenditures Expenditures[]
  sender MoneyTransfer[] @relation("FromSavingAccounts")
  recipient MoneyTransfer[] @relation("ToSavingAccounts")
  purchase Purchase[]
  sales Sales[]
  saleReturns SaleReturns[]
  purchaseReturns PurchaseReturns[]
}

model ProductCategories{
  id String @id
  idStore String
  idProductCategories String?
  imagePath String
  name String
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  parent ProductCategories? @relation("ProductCategories", fields: [idProductCategories], references: [id], onDelete: SetNull, onUpdate: Cascade)
  productCategories ProductCategories[] @relation("ProductCategories")
  product Product[]
}

model Product{
  id String @id
  idStore String
  idProductCategories String?
  imagePath String
  name String
  price Int
  cost Int
  createdAt DateTime @default(now())
  deletedAt DateTime?

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productCategories ProductCategories? @relation(fields: [idProductCategories], references: [id], onDelete: SetNull, onUpdate: Cascade)
  purchaseOrder PurchaseOrder[]
  saleOrder SaleOrder[]
  saleReturnOrders SaleReturnOrders[]
  purchaseReturnOrders PurchaseReturnOrders[]
}

model Purchase{
  id String @id
  idStore String
  idSavingAccount String?
  idSupplier String?
  documentPath String?
  discount Int @default(0)
  shippingCost Int @default(0)
  notes String?
  purchaseStatus PurchaseStatus
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  supplier Supplier? @relation(fields: [idSupplier], references: [id], onDelete: SetNull, onUpdate: Cascade)
  savingAccount SavingAccounts? @relation(fields: [idSavingAccount], references: [id], onUpdate: Cascade, onDelete: SetNull)

  purchaseOrder PurchaseOrder[]
}

model PurchaseOrder{
  id String @id @default(uuid())
  idStore String
  idPurchase String
  idProduct String
  qty Int
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  purchase Purchase @relation(fields: [idPurchase], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product @relation(fields: [idProduct], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Sales{
  id String @id
  idStore String
  idCustomerUser String?
  idSavingAccount String?
  documentPath String?
  saleStatus SaleStatus
  purchaseStatus SalePurchaseStatus
  discount Int @default(0)
  shippingCost Int @default(0)
  saleNotes String?
  staffNotes String?
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  customerUser CustomerUser? @relation(fields: [idCustomerUser], references: [id], onDelete: SetNull, onUpdate: Cascade)
  savingAccount SavingAccounts? @relation(fields: [idSavingAccount], references: [id], onDelete: SetNull, onUpdate: Cascade)
  saleOrder SaleOrder[]
  packaging Packaging[]
}

model SaleOrder{
  id String @id @default(uuid())
  idStore String
  idSale String
  idProduct String
  qty Int
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sale Sales @relation(fields: [idSale], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product @relation(fields: [idProduct], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model ExpenditureCategory{
  id String @id
  idStore String
  name String
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  expenditures Expenditures[]
}

model Expenditures{
  id String @id
  idStore String
  idSavingAccount String?
  idExpenditureCategory String?
  total Int
  notes String?
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  savingAccount SavingAccounts? @relation(fields: [idSavingAccount], references: [id], onDelete: SetNull, onUpdate: Cascade)
  expenditureCategory ExpenditureCategory? @relation(fields: [idExpenditureCategory], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model SaleReturns{
  id String @id
  idStore String
  idCustomerUser String?
  idSavingAccount String?
  notes String?
  createdAt DateTime @default(now())

  savingAccount SavingAccounts? @relation(fields: [idSavingAccount], references: [id], onDelete: SetNull, onUpdate: Cascade)
  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  customerUser CustomerUser? @relation(fields: [idCustomerUser], references: [id], onDelete: SetNull, onUpdate: Cascade)
  saleReturnOrders SaleReturnOrders[]
}

model SaleReturnOrders{
  id String @id @default(uuid())
  idStore String
  idProduct String?
  idSaleReturn String
  qty Int
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product? @relation(fields: [idProduct], references: [id], onDelete: SetNull, onUpdate: Cascade)
  saleReturn SaleReturns @relation(fields: [idSaleReturn], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model PurchaseReturns{
  id String @id
  idStore String
  idSavingAccount String?
  idSupplier String?
  notes String?
  createdAt DateTime @default(now())

  savingAccount SavingAccounts? @relation(fields: [idSavingAccount], references: [id], onDelete: SetNull, onUpdate: Cascade)
  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  supplier Supplier? @relation(fields: [idSupplier], references: [id], onDelete: SetNull, onUpdate: Cascade)
  purchaseReturnOrders PurchaseReturnOrders[]
}

model PurchaseReturnOrders{
  id String @id @default(uuid())
  idStore String
  idProduct String?
  idPurchaseReturn String
  qty Int
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product? @relation(fields: [idProduct], references: [id], onDelete: SetNull, onUpdate: Cascade)
  purchaseReturn PurchaseReturns @relation(fields: [idPurchaseReturn], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Packaging{
  id String @id
  idStore String
  idCustomerUser String?
  idSales String?
  filePath String?
  notes String?
  status PackagingStatus
  address String
  createdAt DateTime @default(now())

  store Store @relation(fields: [idStore], references: [id], onDelete: Cascade, onUpdate: Cascade)
  customerUser CustomerUser? @relation(fields: [idCustomerUser], references: [id], onDelete: SetNull, onUpdate: Cascade)
  sales Sales? @relation(fields: [idSales], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model MoneyTransfer{
  id String @id
  idStore String
  fromSavingAccount String?
  toSavingAccount String?
  total Int
  createdAt DateTime @default(now())

  fromSavingAccountRelation SavingAccounts? @relation("FromSavingAccounts", fields: [fromSavingAccount], references: [id], onDelete: SetNull, onUpdate: Cascade)
  toSavingAccountRelation SavingAccounts? @relation("ToSavingAccounts", fields: [toSavingAccount], references: [id], onDelete: SetNull,onUpdate: Cascade)
}